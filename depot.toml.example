# Starmetal configuration
# Copy to depot.toml or set DEPOT_CONFIG env var

[server]
bind = "127.0.0.1:8080"
# Set when Starmetal is behind a reverse proxy so package metadata emits stable URLs.
# public_base_url = "https://starmetal.internal.example.com"
# Empty means browser clients are not allowed cross-origin access.
cors_allowed_origins = []
max_upload_bytes = 536870912

[storage]
backend = "fs"            # fs | s3 | gcs | memory
path = "/var/lib/starmetal"

# [storage.s3]
# bucket = "starmetal-packages"
# region = "us-east-1"
# endpoint = "https://s3.amazonaws.com"

[upstream.pypi]
enabled = true
url = "https://pypi.org"
max_response_bytes = 536870912

[upstream.npm]
enabled = true
url = "https://registry.npmjs.org"
max_response_bytes = 536870912

[upstream.cargo]
enabled = true
url = "https://index.crates.io"
artifact_url = "https://static.crates.io/crates"
max_response_bytes = 536870912

[upstream.hex]
enabled = true
url = "https://hex.pm"
artifact_url = "https://repo.hex.pm"
max_response_bytes = 536870912

[upstream.maven]
enabled = true
url = "https://repo1.maven.org/maven2"
max_response_bytes = 536870912

[upstream.rubygems]
enabled = true
url = "https://rubygems.org"
artifact_url = "https://rubygems.org"
max_response_bytes = 536870912

[upstream.nuget]
enabled = true
url = "https://api.nuget.org/v3/index.json"
max_response_bytes = 536870912

[upstream.pub]
enabled = true
url = "https://pub.dev"
max_response_bytes = 536870912

[policies]
block_unlicensed = false
max_vuln_severity = "critical"   # low | medium | high | critical
allowed_licenses = []            # empty = allow all
blocked_packages = []

[auth]
enabled = false
tokens = []

[encryption]
enabled = false
# key_file = "/etc/depot/key"
