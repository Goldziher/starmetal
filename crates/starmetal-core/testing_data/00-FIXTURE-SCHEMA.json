{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"title": "Starmetal Test Fixture",
	"type": "object",
	"required": ["name", "input", "expected"],
	"properties": {
		"name": { "type": "string", "description": "Test case name" },
		"description": { "type": "string", "description": "What this tests" },
		"input": { "type": "object", "description": "Test input data" },
		"expected": { "type": "object", "description": "Expected output" },
		"error": {
			"type": ["string", "null"],
			"description": "Expected error message substring, null if success"
		}
	}
}
